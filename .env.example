# ─────────────────────────────────────────────────────────────────────────────
# Job Hunt Agent – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. ANTHROPIC (Claude AI) ──────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
# Free $5 credit on sign-up (~150 tailored resumes)
ANTHROPIC_API_KEY=sk-ant-api03-...


# ── 2. APIFY (Indeed + Wellfound scraping) ────────────────────────────────────
# Get your token at: https://console.apify.com/ → Settings → Integrations
# Free plan: ~500 actor compute units/month (resets monthly)
APIFY_API_TOKEN=apify_api_...


# ── 3. RAPIDAPI (LinkedIn scraping) ──────────────────────────────────────────
# Sign up at: https://rapidapi.com/
# Subscribe to "JSearch" (free tier: 200 req/month):
#   https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here


# ── 4. SLACK (daily job report) ───────────────────────────────────────────────
# Create a Slack app at: https://api.slack.com/apps
#   → Add OAuth scope: chat:write
#   → Install to workspace → copy Bot User OAuth Token
# Get CHANNEL_ID: right-click your channel → View channel details → copy ID at bottom
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXXX


# ── 5. YOUR PERSONAL INFO ─────────────────────────────────────────────────────
# Used to personalise resume tailoring and pre-fill application forms
APPLICANT_NAME=Jane Smith
APPLICANT_EMAIL=jane@example.com
APPLICANT_PHONE=+1 (555) 000-0000
APPLICANT_LOCATION=San Francisco, CA
APPLICANT_LINKEDIN=https://linkedin.com/in/yourprofile
APPLICANT_PORTFOLIO=https://yourportfolio.com
WORK_AUTHORIZATION=yes
REQUIRES_SPONSORSHIP=no
YEARS_EXPERIENCE=5+
DESIRED_SALARY=$120,000 – $150,000
START_DATE=Within 2–4 weeks

# Your resume filename — place the .docx file in the data/ folder
RESUME_FILENAME=resume.docx


# ── 6. SCHEDULING (optional — defaults shown) ─────────────────────────────────
DAILY_REPORT_HOUR=10         # Hour to send Slack report (Pacific time, 24h format)
SCRAPE_INTERVAL_HOURS=2      # How often to scrape for new jobs


# ── 7. APP ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
